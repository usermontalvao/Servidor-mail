# Copie para .env e preencha. NUNCA commitar o .env (ja esta no .gitignore).
# No Portainer, prefira preencher estas variaveis na tela da Stack.

# --- HTTP / seguranca da API de envio ---
# Porta INTERNA do container (nao precisa mudar).
PORT=8080
# Porta publicada no HOST. Aponte o Cloudflare Tunnel para http://localhost:<HOST_PORT>.
# Evite as ja usadas: 9000 (portainer), 8080 (evolution), 8082 (typebot), 8083 (bot).
HOST_PORT=8084
# Token forte. O CRM/edge function envia no header: Authorization: Bearer <este token>
BRIDGE_API_TOKEN=troque-por-um-token-bem-grande-e-aleatorio

# --- IMAP (recebimento) — dados da Hostinger ---
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=contato@seudominio.com
IMAP_PASSWORD=senha-da-caixa
IMAP_MAILBOX=INBOX

# --- SMTP (envio) — dados da Hostinger ---
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contato@seudominio.com
SMTP_PASSWORD=senha-da-caixa
SMTP_FROM="Seu Nome <contato@seudominio.com>"

# --- Supabase ---
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role...

# --- comportamento ---
RECEIVE_ENABLED=true
ATTACHMENTS_BUCKET=email-attachments
LOG_LEVEL=info

# --- Antispam por IA (DeepSeek via edge openai-proxy) ---
# Liga/desliga o refino por IA dos emails recebidos ambíguos. Whitelist/blocklist
# decidem antes; a IA só roda quando não houve decisão por regra.
SPAM_AI_ENABLED=true
# Opcional: sobrescreve o endpoint do proxy. Default: <SUPABASE_URL>/functions/v1/openai-proxy
# SPAM_AI_PROXY_URL=
# OBS: o proxy precisa do secret DEEPSEEK_API_KEY no Supabase (cadeia DeepSeek->Groq->OpenAI).
